{
  "name": "about-me",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:about-me", "type:app"],
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "sourceRoot": "apps/about-me/src",
  "prefix": "app",
  "i18n": {
    "sourceLocale": "en-GB",
    "locales": {
      "fo": "apps/about-me/src/locale/messages.fo.xlf",
      "da": "apps/about-me/src/locale/messages.da.xlf"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "localize": true,
        "outputPath": "dist/apps/about-me",
        "browser": "apps/about-me/src/main.ts",
        "tsConfig": "apps/about-me/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "polyfills": ["zone.js", "@angular/localize/init"],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/about-me/public"
          }
        ],
        "styles": ["apps/about-me/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all",
          "localize": true
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "da": {
          "localize": ["da"]
        },
        "fo": {
          "localize": ["fo"]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "about-me:build:production"
        },
        "development": {
          "buildTarget": "about-me:build:development"
        },
        "da": {
          "buildTarget": "about-me:build:development,da"
        },
        "fo": {
          "buildTarget": "about-me:build:development,fo"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:unit-test"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "about-me:build"
      }
    }
  }
}
